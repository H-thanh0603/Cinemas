# PostgreSQL (Docker Compose default)
DATABASE_URL="postgresql://cinestar:cinestar@localhost:5432/cinestar?schema=public"

# NextAuth (user + admin share this; admin requires role ADMIN in DB)
AUTH_SECRET="change-me-to-a-long-random-string"
# Optional absolute URL for auth callbacks in production
# AUTH_URL="http://localhost:3000"

# Optional: Resend email on confirmed booking
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="CineStar <onboarding@resend.dev>"
# APP_URL="http://localhost:3000"

# Optional: protect expire cron
# CRON_SECRET="your-cron-secret"

# Load test API (/api/loadtest/*) — required for k6 mixed scenario
LOADTEST_SECRET="loadtest-dev-secret"
